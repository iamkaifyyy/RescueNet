datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   // "citizen" or "responder"
  createdAt DateTime @default(now())
}

model Incident {
  id           String   @id @default(uuid())
  title        String
  disasterType String
  place        String
  severity     String
  description  String
  lng          Float
  lat          Float
  reportedBy   String
  status       String   @default("active")
  createdAt    DateTime @default(now())
}

model AssistanceRequest {
  id           String   @id @default(uuid())
  disasterType String
  title        String
  description  String
  location     String
  status       String   @default("pending") // "pending", "dispatched", "resolved"
  severity     String
  createdAt    DateTime @default(now())
}

model VolunteerMission {
  id               String   @id @default(uuid())
  title            String
  location         String
  description      String
  status           String   @default("open")
  volunteersCount  Int      @default(0)
  volunteersNeeded Int      @default(1)
  createdAt        DateTime @default(now())
}
